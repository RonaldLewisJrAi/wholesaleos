# Phase 17: Wholesale OS - Environment Configuration

# === REDIS / BULLMQ QUEUE ===
# Used by worker.cjs to handle long-running background tasks (e.g. Playwright AI Scrapers)
REDIS_URL=redis://127.0.0.1:6379 
# (Or Upstash Serverless Redis String)

# === SUPABASE BACKEND ===
# Copied from Project Settings > API
VITE_SUPABASE_URL=https://[YOUR_PROJECT_ID].supabase.co
VITE_SUPABASE_ANON_KEY=ey...

# === STRIPE MONETIZATION ===
# Required for Billing.jsx and usage tracking limits
STRIPE_SECRET_KEY=sk_test_...
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# === INTELLIGENCE APIS ===
# API Keys strictly isolated to the Node.js backend proxy
OPENAI_API_KEY=sk-...
PROPWIRE_API_KEY=pw_...
RESEND_API_KEY=re_...
